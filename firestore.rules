rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Security Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '4m3i5Kbu9MV2x23vRbYImQpGeDn1' ||
        (request.auth.token.email != null && (
          request.auth.token.email.lower() == 'aleemka14@gmail.com' ||
          request.auth.token.email.lower() == 'futurebillionairehrx@gmail.com'
        ))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users & Profiles Security ---
    match /users/{userId} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }

    // --- Players Collection ---
    match /players/{playerId} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }

    // --- Wallets Collection ---
    match /wallets/{walletId} {
      allow read, write: if true;
    }

    // --- Ledger Transactions Security ---
    match /transactions/{id} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }

    // --- Gameplay History Security ---
    match /gameHistory/{id} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }

    // --- Deposits & Withdrawals Security ---
    match /withdrawals/{id} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }

    match /deposits/{id} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }

    // --- Global Configurations & Settings Security ---
    match /config/{docId} {
      allow read, write: if true;
    }

    match /deposit_networks/{id} {
      allow read, write: if true;
    }

    match /withdrawal_networks/{id} {
      allow read, write: if true;
    }

    match /auditLogs/{id} {
      allow read, write: if true;
    }

    match /system_alerts/{id} {
      allow read, write: if true;
    }

    match /notifications/{id} {
      allow read, write: if true;
    }

    // Connection test
    match /test/{docId} {
      allow read, write: if true; 
    }
  }
}
