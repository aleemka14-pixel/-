rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '4m3i5Kbu9MV2x23vRbYImQpGeDn1' ||
        (request.auth.token.email != null && (
          request.auth.token.email.lower() == 'aleemka14@gmail.com' ||
          request.auth.token.email.lower() == 'futurebillionairehrx@gmail.com'
        ))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collection Rules ---

    match /players/{playerId} {
      // Allow everyone to see the leaderboard (list) and individual profiles (get)
      allow read: if isSignedIn(); 
      allow create: if isOwner(playerId);
      // Allow self-update OR update by joining user (referral logic)
      allow update: if isSignedIn(); 
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Allow self-reads, profile reads, and updates (including referral updates) for authenticated users
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /transactions/{id} {
      // Users can only see their own transactions, admins see all
      allow read: if isSignedIn() && (isAdmin() || resource.data.playerId == request.auth.uid);
      allow create: if isSignedIn(); 
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /withdrawals/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.playerId == request.auth.uid);
      allow create: if isOwner(request.resource.data.playerId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /deposits/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.playerId == request.auth.uid);
      allow create: if isOwner(request.resource.data.playerId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /deposit_networks/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /withdrawal_networks/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Explicitly allow connection test
    match /test/{docId} {
      allow get: if true; 
    }
  }
}
