{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents the secure user wallet and profile.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "walletBalance": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["username", "email", "balance", "createdAt"]
    },
    "Player": {
      "title": "Player",
      "description": "Represents a user profile in the game.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "override": { "type": "string", "enum": ["win", "lose", "none"] },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "referralCount": { "type": "number" },
        "pendingBet": {
          "type": "object",
          "properties": {
            "amount": { "type": "number" },
            "timestamp": { "type": "number" }
          }
        }
      },
      "required": ["id", "name", "balance", "override", "referralCode", "referralCount"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "Blockchain wallet assigned to a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "walletAddress": { "type": "string" },
        "network": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "walletAddress", "network", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial records of the player.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "playerId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "bet", "win", "withdrawal"] },
        "amount": { "type": "number" },
        "timestamp": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed", "confirmed"] },
        "transactionId": { "type": "string" },
        "userId": { "type": "string" },
        "network": { "type": "string" },
        "transactionHash": { "type": "string" },
        "balanceBefore": { "type": "number" },
        "balanceAfter": { "type": "number" },
        "referenceId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "playerId", "type", "amount", "timestamp", "status"]
    },
    "WithdrawalRequest": {
      "title": "Withdrawal",
      "description": "Player request to withdraw funds.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "playerId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "details": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "rejected", "failed", "cancelled", "reviewing", "approved", "broadcasted"] },
        "timestamp": { "type": "number" },
        "playerBalanceAtRequest": { "type": "number" },
        "withdrawalId": { "type": "string" },
        "userId": { "type": "string" },
        "network": { "type": "string" },
        "withdrawalAddress": { "type": "string" },
        "transactionHash": { "type": "string" },
        "createdAt": { "type": "number" },
        "completedAt": { "type": "number" },
        "processedAt": { "type": "number" }
      },
      "required": ["id", "playerId", "amount", "status", "timestamp"]
    },
    "DepositRequest": {
      "title": "Deposit",
      "description": "Player report of a deposit.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "playerId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "details": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "rejected", "confirmed"] },
        "timestamp": { "type": "number" },
        "playerBalanceAtRequest": { "type": "number" },
        "depositId": { "type": "string" },
        "userId": { "type": "string" },
        "network": { "type": "string" },
        "walletAddress": { "type": "string" },
        "transactionHash": { "type": "string" },
        "createdAt": { "type": "number" },
        "confirmedAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "playerId", "amount", "status", "timestamp"]
    },
    "GameHistory": {
      "title": "GameHistory",
      "description": "Gameplay record of bets and outcomes.",
      "type": "object",
      "properties": {
        "gameId": { "type": "string" },
        "userId": { "type": "string" },
        "entryAmount": { "type": "number" },
        "result": { "type": "string" },
        "payout": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["gameId", "userId", "entryAmount", "result", "payout", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global administrator settings.",
      "type": "object",
      "properties": {
        "winRate": { "type": "number" },
        "manualMode": { "type": "boolean" },
        "maxBet": { "type": "number" },
        "isBetLimitEnabled": { "type": "boolean" },
        "maintenanceMode": { "type": "boolean" },
        "isPaymentLocked": { "type": "boolean" },
        "paymentSettings": {
          "type": "object",
          "properties": {
            "upiId": { "type": "string" },
            "qrCodeUrl": { "type": "string" },
            "additionalInstructions": { "type": "string" }
          }
        }
      }
    },
    "FAQItem": {
      "title": "FAQItem",
      "description": "Single FAQ question and answer",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" }
      },
      "required": ["question", "answer"]
    },
    "DepositNetwork": {
      "title": "DepositNetwork",
      "description": "Represents a blockchain network configuration for deposit.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "networkFeeText": { "type": "string" },
        "typicalFeeUsd": { "type": "number" },
        "estimatedTime": { "type": "string" },
        "confirmations": { "type": "number" },
        "warningMessage": { "type": "string" },
        "depositInstructions": { "type": "string" },
        "helpText": { "type": "string" },
        "maintenanceMessage": { "type": "string" },
        "statusBadge": { "type": "string", "enum": ["Online", "Maintenance"] },
        "enabled": { "type": "boolean" },
        "minDepositUsd": { "type": "number" },
        "maxDepositUsd": { "type": "number" },
        "depositAddress": { "type": "string" },
        "qrCodeUrl": { "type": "string" },
        "priority": { "type": "number" },
        "featured": { "type": "boolean" }
      },
      "required": ["id", "name", "depositAddress", "minDepositUsd", "maxDepositUsd", "enabled", "priority", "statusBadge"]
    },
    "WithdrawalNetwork": {
      "title": "WithdrawalNetwork",
      "description": "Represents a blockchain network configuration for withdrawal.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "averageFee": { "type": "number" },
        "networkFeeText": { "type": "string" },
        "estimatedTime": { "type": "string" },
        "popularityBadge": { "type": "string" },
        "securityRating": { "type": "number" },
        "status": { "type": "string", "enum": ["Online", "Maintenance"] },
        "warningMessage": { "type": "string" },
        "instructions": { "type": "string" },
        "minWithdraw": { "type": "number" },
        "maxWithdraw": { "type": "number" },
        "priority": { "type": "number" },
        "enabled": { "type": "boolean" }
      },
      "required": ["id", "name", "minWithdraw", "maxWithdraw", "enabled", "priority", "status"]
    },
    "WithdrawalSettings": {
      "title": "WithdrawalSettings",
      "description": "Administrator settings for withdrawals.",
      "type": "object",
      "properties": {
        "minWithdraw": { "type": "number" },
        "maxWithdraw": { "type": "number" },
        "dailyWithdrawLimit": { "type": "number" },
        "autoWithdrawEnabled": { "type": "boolean" },
        "manualApprovalEnabled": { "type": "boolean" },
        "maintenanceMode": { "type": "boolean" },
        "allowedBlockchains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "networkPriority": { "type": "object" },
        "defaultFee": { "type": "number" },
        "defaultProcessingTime": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Secure wallets and user accounts indexed by UID."
    },
    "wallets": {
      "schema": "Wallet",
      "description": "Configured user crypto wallets."
    },
    "deposit_networks": {
      "schema": "DepositNetwork",
      "description": "Dynamic configurations for deposit blockchain networks."
    },
    "withdrawal_networks": {
      "schema": "WithdrawalNetwork",
      "description": "Dynamic configurations for withdrawal blockchain networks."
    },
    "players": {
      "schema": "Player",
      "description": "User profiles indexed by UID."
    },
    "transactions": {
      "schema": "Transaction",
      "description": "System-wide transactions."
    },
    "withdrawals": {
      "schema": "WithdrawalRequest",
      "description": "Payment requests."
    },
    "deposits": {
      "schema": "DepositRequest",
      "description": "Confirmation requests."
    },
    "gameHistory": {
      "schema": "GameHistory",
      "description": "Gameplay ledger for analytics and history tracing."
    },
    "config/admin": {
      "schema": "Settings",
      "description": "Global settings document."
    },
    "config/withdrawal_settings": {
      "schema": "WithdrawalSettings",
      "description": "Withdrawal specific global settings."
    }
  }
}
