# ==============================================================================
# SECURE CONFIGURATION & ENVIRONMENT VARIABLES REFERENCE (.env.example)
# ==============================================================================
# This file documents all available and required environment variables for the
# application. Copy this file to a ".env" file in your workspace root to configure
# local development.
# 
# WARNING: NEVER commit actual secrets, API keys, or private credentials to source
# control. This file must only contain placeholders.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE APPLICATION ENVIRONMENT
# ------------------------------------------------------------------------------

# GEMINI_API_KEY: Required for Gemini AI API operations.
# Note: In Google AI Studio, this key is automatically injected from user secrets.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The public hostname/URL where this applet is hosted.
# Used for self-referential links, NOWPayments IPN webhook callbacks, etc.
APP_URL="https://your-domain.com"


# ------------------------------------------------------------------------------
# 2. FIREBASE / FIRESTORE ENVIRONMENT
# ------------------------------------------------------------------------------
# Configures the Firestore Database connection. Fallback values are pulled from 
# thecommitted firebase-applet-config.json when these are unset.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""


# ------------------------------------------------------------------------------
# 3. SECURE ADMIN CREDENTIALS
# ------------------------------------------------------------------------------
# These passwords are used by server-side verification handlers (/api/admin/verify-auth)
# and are never exposed, transmitted, or compiled into the client-side bundle.

# ADMIN_PASSKEY: The security code used by authorized administrators to log in.
# Default fallback (if left blank): "9113278916"
ADMIN_PASSKEY="9113278916"

# ADMIN_CONFIRM_PASSWORD: The high-level action/transaction confirmation password.
# Default fallback (if left blank): "admin123"
ADMIN_CONFIRM_PASSWORD="admin123"


# ------------------------------------------------------------------------------
# 4. PAYMENT ROUTING & WEBHOOK SECURITY
# ------------------------------------------------------------------------------

# CRYPTO_WEBHOOK_SECRET: Secret token for verifying webhook authenticity.
# Maps directly to the IPN Secret for Direct Crypto Transfer notifications.
# Default fallback: "DIRECT_CRYPTO_SECRET_992"
CRYPTO_WEBHOOK_SECRET="DIRECT_CRYPTO_SECRET_992"

# NOWPAYMENTS_API_KEY: API secret key for sending payment creation queries.
NOWPAYMENTS_API_KEY=""

# NOWPAYMENTS_IPN_SECRET: Signing secret for Instant Payment Notification authentication.
NOWPAYMENTS_IPN_SECRET=""


# ------------------------------------------------------------------------------
# 5. REVENUE WALLET ROUTING CONFIGURATION
# ------------------------------------------------------------------------------
# Default wallet addresses for incoming customer deposits.

DIRECT_CRYPTO_USDT_TRC20_ADDRESS="TYb3jV2kR7K3XvSNoK83A7NnBkWqE9M2S4h"
DIRECT_CRYPTO_USDT_BEP20_ADDRESS="0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174"
DIRECT_CRYPTO_USDT_ERC20_ADDRESS="0xdAC17F958D2ee523a2206206994597C13D831ec7"

# UPI payments routing
UPI_ID="merchant@upi"
UPI_QR_CODE_URL=""


# ------------------------------------------------------------------------------
# 6. SYSTEM HOT WALLET ROUTING
# ------------------------------------------------------------------------------
# Configuration parameters for automatic processing of withdrawal requests.

# ACTIVE_WALLET_PROVIDER: Chooses the active transaction provider.
# Allowed: "mock" (simulated node sandbox) or "live"
ACTIVE_WALLET_PROVIDER="mock"

# Outgoing transaction Hot Wallets
TRC20_HOT_WALLET="TYG8D6FidA5A1t6bZ7rFvHkC9dE9fG7hI1"
BEP20_HOT_WALLET="0x51C7656EC7ab88b098defB751B7401B5f6d8976F"
ERC20_HOT_WALLET="0x71C7656EC7ab88b098defB751B7401B5f6d8976F"

# System Reserve Wallets (used for automatic gas refilling)
TRC20_RESERVE_WALLET="TLZ8v6FidA5A1t6bZ7rFvHkC9dE9fG7hX9"
BEP20_RESERVE_WALLET="0x1A2B3C4D5E6F7G8H9I0J1K2L3M4N5O6P7Q8R9S0T"
ERC20_RESERVE_WALLET="0x99C7656EC7ab88b098defB751B7401B5f6d8976F"

# External Blockchain Node Providers
TRON_RPC_URL="https://api.trongrid.io"
BSC_RPC_URL="https://bsc-dataseed.binance.org/"
ETH_RPC_URL="https://cloudflare-eth.com"
